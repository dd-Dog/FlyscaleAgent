# Copy to .env. 大模型的 base_url / model / temperature 等在 models.yaml 中配置；
# 此处只放 FlyAgent 服务配置，以及 models.yaml 里 api_key_env 所指向的密钥。


# --- 阿里云智能语音交互 NLS（实时/一句话识别），SDK: https://github.com/aliyun/alibabacloud-nls-python-sdk ---
# 控制台创建「智能语音交互」项目后获取 AppKey；AccessKey 使用 RAM 子账号密钥更安全。
NLS_ACCESS_KEY_ID=
NLS_ACCESS_KEY_SECRET=
NLS_APP_KEY=
# 可选：默认上海网关；其他区域见阿里云文档
# NLS_GATEWAY_URL=wss://nls-gateway.cn-shanghai.aliyuncs.com/ws/v1
# NLS_TOKEN_REGION=cn-shanghai
# NLS_FLASH_URL=https://nls-gateway-cn-shanghai.aliyuncs.com/stream/v1/FlashRecognizer
# NLS 在线语音合成（SpeechSynthesizer）可选参数
# NLS_TTS_VOICE=xiaoyun
# NLS_TTS_FORMAT=mp3
# NLS_TTS_SAMPLE_RATE=16000
# NLS_TTS_VOLUME=50
# NLS_TTS_SPEECH_RATE=0
# NLS_TTS_PITCH_RATE=0

# --- 安全（部署建议全部设置）---
# 调用 POST /api/chat 时须在请求头携带：X-API-Key: <密钥> 或 Authorization: Bearer <密钥>
FLYAGENT_API_KEY=

# 管理页登录；两者都非空时启用。启用后必须设置 FLYAGENT_SESSION_SECRET（随机长字符串，用于 Cookie 签名）
FLYAGENT_ADMIN_USER=
FLYAGENT_ADMIN_PASSWORD=
FLYAGENT_SESSION_SECRET=
