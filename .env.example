# Copy to .env. 大模型的 base_url / model / temperature 等在 models.yaml 中配置；
# 内置工具 URL / RSS / 航班下游见 tools_config.yaml，路径可覆盖为：
# FLYAGENT_TOOLS_CONFIG_PATH=tools_config.yaml
# 此处只放 FlyAgent 服务配置，以及 models.yaml 里 api_key_env 所指向的密钥。


# --- 阿里云智能语音交互 NLS（实时/一句话识别），SDK: https://github.com/aliyun/alibabacloud-nls-python-sdk ---
# 控制台创建「智能语音交互」项目后获取 AppKey；AccessKey 使用 RAM 子账号密钥更安全。
NLS_ACCESS_KEY_ID=
NLS_ACCESS_KEY_SECRET=
NLS_APP_KEY=
# 可选：默认上海网关；其他区域见阿里云文档
# NLS_GATEWAY_URL=wss://nls-gateway.cn-shanghai.aliyuncs.com/ws/v1
# NLS_TOKEN_REGION=cn-shanghai
# CreateToken 域名与版本（一般勿改）；token 按返回的 ExpireTime 缓存，约 24h 内复用
# NLS_TOKEN_META_DOMAIN=nls-meta.cn-shanghai.aliyuncs.com
# NLS_TOKEN_API_VERSION=2019-02-28
# 在 ExpireTime 之前提前多少秒重新申请（默认 300）
# NLS_TOKEN_REFRESH_MARGIN_SEC=300
# NLS_FLASH_URL=https://nls-gateway-cn-shanghai.aliyuncs.com/stream/v1/FlashRecognizer
# NLS 在线语音合成（SpeechSynthesizer）可选参数
# NLS_TTS_VOICE=xiaoyun
# NLS_TTS_FORMAT=mp3
# NLS_TTS_SAMPLE_RATE=16000
# NLS_TTS_VOLUME=50
# NLS_TTS_SPEECH_RATE=0
# NLS_TTS_PITCH_RATE=0

# --- 安全（部署建议全部设置）---
# 调用 POST /api/chat 时须在请求头携带：X-API-Key: <密钥> 或 Authorization: Bearer <密钥>
FLYAGENT_API_KEY=

# 管理页登录；两者都非空时启用。启用后必须设置 FLYAGENT_SESSION_SECRET（随机长字符串，用于 Cookie 签名）
FLYAGENT_ADMIN_USER=
FLYAGENT_ADMIN_PASSWORD=
FLYAGENT_SESSION_SECRET=

# --- 内置工具（天气 Open-Meteo / 新闻 Google News RSS）与上传音频时长 ---
# FLYAGENT_TOOLS_ENABLED=true
# 一级规则（地名+天气/新闻）先服务端调工具再单次 LLM；设为 false 则一律走 OpenAI tools 多轮
# FLYAGENT_TOOLS_TIER1_ENABLED=true
# 单次请求最多调用 chat/completions 次数（含工具后续轮，默认 6）
# FLYAGENT_TOOLS_MAX_MODEL_CALLS=6
# ASR 上传最大时长（秒），默认 300；设为 0 关闭校验
# FLYAGENT_AUDIO_MAX_DURATION_SEC=300
# Tool 循环 / LLM 详细日志文件（空字符串=不写文件，仅控制台若已配置）；DEBUG 可打出 messages 截断 JSON
# FLYAGENT_LLM_TOOL_TRACE_PATH=data/llm_tool_trace.log
